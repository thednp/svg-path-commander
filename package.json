{
  "name": "svg-path-commander",
  "author": "thednp",
  "license": "MIT",
  "version": "2.2.0",
  "description": "🛹 Modern TypeScript tools for SVG",
  "main": "./dist/index.js",
  "browser": "./dist/index.min.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./util": "./dist/util.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "pre-test": "pnpm clean-coverage",
    "dev": "vite serve docs --port 3000",
    "test": "vitest",
    "test-ui": "vitest --ui",
    "clean-coverage": "rm -rf coverage .nyc_output",
    "format": "deno fmt src",
    "lint": "pnpm lint:ts && pnpm check:ts",
    "fix:ts": "deno lint --fix src",
    "lint:ts": "deno lint src",
    "check:ts": "tsc --noEmit",
    "build_": "tsdown && pnpm build-iife && pnpm copy-docs",
    "build": "tsdown && pnpm copy-docs",
    "build-iife": "vite build --config vite.config.ts",
    "copy-docs": "cp dist/index.min.js docs/index.min.js && cp dist/index.min.js.map docs/index.min.js.map",
    "prepublishOnly": "pnpm update --latest && pnpm format && pnpm lint:ts && pnpm build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thednp/svg-path-commander.git"
  },
  "keywords": [
    "svg",
    "path",
    "commander",
    "parse",
    "normalize",
    "optimize",
    "reverse",
    "convert",
    "absolute",
    "relative",
    "curve",
    "transform3d",
    "typescript"
  ],
  "bugs": {
    "url": "https://github.com/thednp/svg-path-commander/issues"
  },
  "homepage": "http://thednp.github.io/svg-path-commander",
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@vitest/browser": "^4.1.2",
    "@vitest/coverage-istanbul": "^4.1.2",
    "@vitest/ui": "^4.1.2",
    "happy-dom": "^20.8.9",
    "playwright": "^1.59.1",
    "tsdown": "0.21.7",
    "typescript": "^6.0.2",
    "vite": "^8.0.4",
    "vite-plugin-strip-comments": "^0.0.10",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@thednp/dommatrix": "^3.0.4"
  },
  "engines": {
    "node": ">=16",
    "pnpm": ">=8.6.0"
  },
  "packageManager": "pnpm@10.33.0",
  "inlinedDependencies": {
    "@thednp/dommatrix": "3.0.4"
  }
}
